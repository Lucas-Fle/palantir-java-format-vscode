{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "types": [
      "node",
      "vscode"
    ]
  },
  "include": [
    "extension/src/**/*.ts",
    "extension/test/**/*.ts",
    "vitest.config.mts"
  ]
}
