{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lucasfleury/palantir-java-format-worker/protocol/v1",
  "title": "Palantir Java Format Worker Protocol v1",
  "oneOf": [
    {
      "$ref": "#/$defs/request"
    },
    {
      "$ref": "#/$defs/response"
    }
  ],
  "$defs": {
    "request": {
      "type": "object",
      "required": [
        "protocolVersion",
        "id",
        "method",
        "params"
      ],
      "properties": {
        "protocolVersion": {
          "const": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "enum": [
            "initialize",
            "formatDocument",
            "shutdown"
          ]
        },
        "params": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "response": {
      "type": "object",
      "required": [
        "protocolVersion",
        "id"
      ],
      "properties": {
        "protocolVersion": {
          "const": 1
        },
        "id": {
          "type": [
            "string",
            "null"
          ]
        },
        "result": {},
        "error": {
          "type": "object",
          "required": [
            "code",
            "message"
          ],
          "properties": {
            "code": {
              "type": "string"
            },
            "message": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "oneOf": [
        {
          "required": [
            "result"
          ]
        },
        {
          "required": [
            "error"
          ]
        }
      ],
      "additionalProperties": false
    }
  }
}
